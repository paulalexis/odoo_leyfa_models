<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_contract_intro" model="ir.ui.view">
        <field name="name">sale.order.form.contract.intro</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
<page string="Devis LEYFA" name="contract_intro">

    <group>
        <group>
            <field name="quote_number_custom"/>
        </group>
        <group>
            <field name="revision_avenant_prefix" readonly="1" nolabel="1"/>
        </group>
    </group>

    <div class="o_horizontal_separator mt-4 mb-2"><strong>Contact envoi commande</strong></div>
    <group>
        <div class="o_row">
            <label for="user_receive_commande" string="Utilisateur de réception"/>
            <field name="user_receive_commande"/>
            <field name="is_default_receiver" invisible="1"/>
            <button 
                name="action_set_as_default_receiver"
                type="object"
                string="Par défaut"
                icon="fa-check-circle"
                class="btn-success"
                invisible="is_default_receiver"
                title="Définir comme utilisateur par défaut pour les prochains devis"
            />
            <span 
                invisible="not is_default_receiver" 
                class="badge text-bg-secondary ms-2">
                <i class="fa fa-check me-1" title="Utilisateur par défaut"/>Par défaut
            </span>
        </div>
    </group>

    <div class="o_horizontal_separator mt-4 mb-2"><strong>Texte d'introduction spécifique à ce devis</strong></div>
    <field name="contract_intro_text" widget="html" nolabel="1"
        placeholder="Saisissez ici l'introduction spécifique à ce client..."/>

</page>
            </xpath>
        </field>
    </record>
</odoo>