<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_order_form_contract_intro" model="ir.ui.view">
        <field name="name">sale.order.form.contract.intro</field>
        <field name="model">sale.order</field>
        <field name="inherit_id" ref="sale.view_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Introduction du devis" name="contract_intro">
                    <group>
                        <separator string="Contact envoi commande"/>
                        <label for="user_receive_commande"/>
                        <div class="o_row">
                            <field name="user_receive_commande"/>
                            <field name="is_default_receiver" invisible="1"/>
                            <button 
                                name="action_set_as_default_receiver"
                                type="object"
                                string="Par défaut"
                                icon="fa-check-circle"
                                class="btn-success"
                                invisible="is_default_receiver"
                                title="Définir comme utilisateur par défaut pour les prochains devis"
                            />
                            <span 
                                invisible="not is_default_receiver" 
                                class="badge text-bg-secondary ms-2">
                                <i class="fa fa-check me-1" title="Utilisateur par défaut"/>Par défaut
                            </span>
                        </div>

                        <separator string="Texte d'introduction spécifique à ce devis"/>
                        <!-- colspan="2" makes the field stretch across the label and field columns -->
                        <field name="contract_intro_text" widget="html" nolabel="1" colspan="2"
                            placeholder="Saisissez ici l'introduction spécifique à ce client..."/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>