<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- LIST VIEW -->
    <record id="contrat_list_view" model="ir.ui.view">
        <field name="name">rail.measurement.contrat.list</field>
        <field name="model">rail.measurement.contrat</field>
        <field name="arch" type="xml">
            <list string="Contrats">
                <field name="name"/>
                <field name="client_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="quotation_template_id"/>
            </list>
        </field>
    </record>

    <!-- FORM VIEW -->
    <record id="contrat_form_view" model="ir.ui.view">
        <field name="name">rail.measurement.contrat.form</field>
        <field name="model">rail.measurement.contrat</field>
        <field name="arch" type="xml">
            <form string="Contrat">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="client_id"/>
                        </group>
                        <group>
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="quotation_template_id"/>
                            <field name="report_template_id"/>
                        </group>
                    </group>
                    <div class="o_field_widget" style="width: 100%;">
                        <field name="description" nolabel="1"/>
                    </div>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ACTION -->
    <record id="action_contrat" model="ir.actions.act_window">
        <field name="name">Contrats</field>
        <field name="res_model">rail.measurement.contrat</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>