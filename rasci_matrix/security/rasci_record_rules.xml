<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Users NOT in group_rasci_manager can only see projects where they are pilot or member -->
    <record id="rule_rasci_project_personal" model="ir.rule">
        <field name="name">RASCI Project: accès personnel uniquement</field>
        <field name="model_id" ref="model_rasci_project"/>
        <field name="domain_force">[
            '|',
            ('pilot_id.user_id', '=', user.id),
            ('member_ids.employee_id.user_id', '=', user.id)
        ]</field>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="False"/>
        <field name="perm_create" eval="False"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <!-- Managers see everything -->
    <record id="rule_rasci_project_manager" model="ir.rule">
        <field name="name">RASCI Project: accès gestionnaire</field>
        <field name="model_id" ref="model_rasci_project"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('rasci_matrix.group_rasci_manager')), (4, ref('base.group_system'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="True"/>
    </record>
</odoo>